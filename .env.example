# KUBER — API Key Configuration
# Copy this file to .env and fill in your keys.
# Never commit .env to version control!

# FRED API key (required for macro data)
# Get from: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_key_here

# Anthropic Claude API key (optional — for LLM-powered memos)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_claude_key_here

# News API key (optional — for real news sentiment)
# Get from: https://newsapi.org/
NEWS_API_KEY=your_news_key_here
